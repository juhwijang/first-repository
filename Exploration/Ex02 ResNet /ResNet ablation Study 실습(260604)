   "source": [
    "class VGGNet(nn.Module):\n",
    "    def __init__(self):\n",
    "        super(VGGNet, self).__init__()\n",
    "\n",
    "        # VGG 블록 생성\n",
    "        self.vgg_block = build_vgg_block(torch.zeros(1, 3, 32, 32))\n",
    "    def forward(self, x):\n",
    "        return self.vgg_block(x)"
   ]
