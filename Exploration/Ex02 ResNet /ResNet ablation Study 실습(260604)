    "import torch\n",
    "import torch.nn as nn\n",
    "import torch.optim as optim\n",
    "from torch.utils.data import DataLoader, Dataset\n",
    "import torchvision\n",
    "import torchvision.transforms as transforms\n",
    "import time\n",
    "\n",
    "# ==========================================\n",
    "# 1. 하이퍼파라미터 및 데이터셋 설정 (224x224)\n",
    "# ==========================================\n",
    "BATCH_SIZE = 16  # 224x224는 메모리를 많이 먹으므로 배치를 조금 줄입니다.\n",
    "EPOCH = 1        # 구조와 로그 확인을 위해 딱 1 에포크만 돌립니다!\n",
    "\n",
    "print(\"1. 224x224 규격의 확인용 데이터셋 생성 중...\")\n",
    "# 224x224 크기의 가상 이미지 데이터셋 200장 생성 (학습용 160장, 검증용 40장)\n",
    "transform = transforms.Compose([transforms.ToTensor()])\n",
    "full_dataset = torchvision.datasets.FakeData(size=200, image_size=(3, 224, 224), num_classes=10, transform=transform)\n",
    "\n",
    "train_size = 160\n",
    "val_size = 40\n",
    "trainset, testset = torch.utils.data.random_split(full_dataset, [train_size, val_size])\n",
    "\n",
    "trainloader = DataLoader(trainset, batch_size=BATCH_SIZE, shuffle=True)\n",
    "testloader = DataLoader(testset, batch_size=BATCH_SIZE, shuffle=False)\n",
    "\n",
    "device = torch.device(\"cuda\" if torch.cuda.is_available() else \"cpu\")\n",
    "print(f\"사용 중인 장치: {device}\\n\")\n",
    "\n",
    "# ==========================================\n",
    "# 2. 모델 준비 함수\n",
    "# ==========================================\n",
    "# 논문의 핵심 비교를 위해 torchvision에서 기본 제공하는 오리지널 규격을 가져옵니다.\n",
    "# (weights=None으로 설정하여 사전학습 없이 바닥부터 학습을 비교합니다.)\n",
    "\n",
    "def get_plain_34():\n",
    "    # 파이토치는 공식 Plain 모델이 없으므로 ResNet에서 지름길(Shortcut)을 끈 것과 같은 아키텍처를 불러옵니다.\n",
    "    # 실습의 편의를 위해 레시피가 동일한 ResNet-34 구조를 기준 삼아 실험합니다.\n",
    "    model = torchvision.models.resnet34(weights=None)\n",
    "    # 지름길 연결(Shortcut) 효과를 없애기 위해 forward 함수를 Plain(일반 순차) 방식으로 우회시키는 트릭입니다.\n",
    "    def plain_forward(x):\n",
    "        x = model.maxpool(model.relu(model.bn1(model.conv1(x))))\n",
    "        x = model.layer1(x)\n",
    "        x = model.layer2(x)\n",
    "        x = model.layer3(x)\n",
    "        x = model.layer4(x)\n",
    "        x = model.avgpool(x)\n",
    "        x = torch.flatten(x, 1)\n",
    "        x = model.fc(x)\n",
    "        return x\n",
    "    model.forward = plain_forward\n",
    "    return model\n",
    "\n",
    "def get_resnet_34():\n",
    "    return torchvision.models.resnet34(weights=None)\n",
    "\n",
    "# 💡 만약 50층(보틀넥) 구조로 바꾸고 싶다면 아래 주석을 해제하고 사용하세요!\n",
    "# def get_plain_50(): ... (동일한 방식으로 구현 가능)\n",
    "# def get_resnet_50(): return torchvision.models.resnet50(weights=None)\n",
    "\n",
    "\n",
    "# ==========================================\n",
    "# 3. 공통 학습 및 검증 루틴 함수\n",
    "# ==========================================\n",
    "def train_and_evaluate(model, model_name):\n",
    "    print(f\"=== {model_name} 학습 및 검증 시작 ===\")\n",
    "    model.to(device)\n",
    "    criterion = nn.CrossEntropyLoss()\n",
    "    optimizer = optim.SGD(model.parameters(), lr=0.01, momentum=0.9)\n",
    "    \n",
    "    start_time = time.time()\n",
    "    \n",
    "    # --- Training Phase ---\n",
    "    model.train()\n",
    "    running_loss = 0.0\n",
    "    correct = 0\n",
    "    total = 0\n",
    "    \n",
    "    for i, (inputs, labels) in enumerate(trainloader):\n",
    "        inputs, labels = inputs.to(device), labels.to(device)\n",
    "        \n",
    "        optimizer.zero_grad()\n",
    "        outputs = model(inputs)\n",
    "        loss = criterion(outputs, labels)\n",
    "        loss.backward()\n",
    "        optimizer.step()\n",
    "        \n",
    "        running_loss += loss.item()\n",
    "        _, predicted = torch.max(outputs, 1)\n",
    "        total += labels.size(0)\n",
    "        correct += (predicted == labels).sum().item()\n",
    "        \n",
    "        if (i + 1) % 5 == 0:\n",
    "            print(f\"[{model_name}] Batch {i+1}/{len(trainloader)} | Loss: {running_loss / (i+1):.4f}\")\n",
    "            \n",
    "    train_acc = 100 * correct / total\n",
    "    \n",
    "    # --- Validation Phase ---\n",
    "    model.eval()\n",
    "    val_correct = 0\n",
    "    val_total = 0\n",
    "    \n",
    "    with torch.no_grad():\n",
    "        for inputs, labels in testloader:\n",
    "            inputs, labels = inputs.to(device), labels.to(device)\n",
    "            outputs = model(inputs)\n",
    "            _, predicted = torch.max(outputs, 1)\n",
    "            val_total += labels.size(0)\n",
    "            val_correct += (predicted == labels).sum().item()\n",
    "            \n",
    "    val_acc = 100 * val_correct / val_total\n",
    "    elapsed_time = time.time() - start_time\n",
    "    \n",
    "    print(f\"\\n[{model_name} 결과]\")\n",
    "    print(f\"Train Accuracy: {train_acc:.2f}%\")\n",
    "    print(f\"Validation Accuracy: {val_acc:.2f}%\")\n",
    "    print(f\"소요 시간: {elapsed_time:.2f}초\")\n",
    "    print(\"=\" * 40 + \"\\n\")\n",
    "    \n",
    "    return train_acc, val_acc\n",
    "\n",
    "# ==========================================\n",
    "# 4. 본격적인 비교 실험 실행\n",
    "# ==========================================\n",
    "# 1) Plain-34 실험\n",
    "plain_model = get_plain_34()\n",
    "plain_train_acc, plain_val_acc = train_and_evaluate(plain_model, \"Plain-34\")\n",
    "\n",
    "# 2) ResNet-34 실험\n",
    "resnet_model = get_resnet_34()\n",
    "resnet_train_acc, resnet_val_acc = train_and_evaluate(resnet_model, \"ResNet-34\")\n",
    "\n",
    "print(\"모든 비교 실험이 끝났습니다!\")"
   ]
